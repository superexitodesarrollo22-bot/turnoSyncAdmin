{
  "expo": {
    "name": "TurnoSync Admin",
    "slug": "turnosync-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "turnosyncadmin",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.turnosync.admin"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D1A"
      },
      "package": "com.turnosync.admin",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C9A84C"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0D1A",
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#0D0D1A",
            "image": "./assets/splash.png"
          },
          "light": {
            "backgroundColor": "#F5F5F0",
            "image": "./assets/splash-light.png"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}